# ============================================================================
# LexFlow Trust Service — Environment Variables
# Copy to .env and fill in values
# REF: GOV-008 §3.2, AGT-003-BE §6
# ============================================================================

# Database connection string for lexflow_trust
DATABASE_URL=postgresql://lexflow_trust:changeme@localhost:5432/lexflow_trust

# Shared secret for inter-service authentication (CON-001 §1.2)
INTERNAL_SERVICE_KEY=changeme-generate-a-real-key

# Service port (CON-002 §1)
PORT=4000

# Environment: development | staging | production
NODE_ENV=development

# Logging level: trace | debug | info | warn | error | fatal (GOV-006 §2)
LOG_LEVEL=debug

# Service name for structured logs (GOV-006 §3.1)
SERVICE_NAME=lexflow-trust

# Persistent log file path — JSONL output (GOV-006 §4, SPR-008 T-088)
# When set, logs are written to both stdout AND this file.
# Production default: /var/log/lexflow/trust.log
# LOG_FILE=/var/log/lexflow/trust.log
